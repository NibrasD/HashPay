{
  "name": "hashpay",
  "version": "1.0.0",
  "description": "HashPay - Privacy-First Payment Protocol on HashKey Chain",
  "type": "module",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:testnet": "npx hardhat run scripts/deploy.js --network hashkeyTestnet",
    "deploy:local": "npx hardhat run scripts/deploy.js --network hardhat",
    "start": "npm install && node server.js",
    "dev": "npm install && node server.js",
    "build": "npm install && npm run build -w frontend"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "dotenv": "^16.3.1"
  }
}
